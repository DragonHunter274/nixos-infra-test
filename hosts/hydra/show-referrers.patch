+[% WRAPPER layout.tt title="Referrers of $path" %]
+[% PROCESS common.tt %]
+[% USE HTML %]
+
+<p>The following store paths refer to <tt>[% HTML.escape(path) %]</tt>:</p>
+
+[% IF referrers.size == 0 %]
+  <p><em>No other store paths reference this path.</em></p>
+[% ELSE %]
+  <table class="table table-striped table-condensed">
+    <tbody>
+      [% FOREACH r IN referrers %]
+        <tr><td><tt>[% HTML.escape(r) %]</tt></td></tr>
+      [% END %]
+    </tbody>
+  </table>
+[% END %]
+
