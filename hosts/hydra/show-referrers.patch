diff --git a/subprojects/hydra/lib/Hydra/Controller/Build.pm b/subprojects/hydra/lib/Hydra/Controller/Build.pm
index ca9a22cf..ba04583b 100644
--- a/subprojects/hydra/lib/Hydra/Controller/Build.pm
+++ b/subprojects/hydra/lib/Hydra/Controller/Build.pm
@@ -501,6 +501,32 @@ sub runtime_deps : Chained('buildChain') PathPart('runtime-deps') {
 }
 
 
+sub referrers : Chained('buildChain') PathPart('referrers') {
+    my ($self, $c, $stepnr, $outputName) = @_;
+
+    notFound($c, "No build step or output specified.") unless defined $stepnr && defined $outputName;
+
+    requireLocalStore($c);
+
+    my $step = $c->stash->{build}->buildsteps->find({stepnr => $stepnr});
+    notFound($c, "Build doesn't have a build step $stepnr.") if !defined $step;
+
+    my $output = $step->buildstepoutputs->find({name => $outputName});
+    notFound($c, "Build step $stepnr has no output named ‘$outputName’.") if !defined $output;
+
+    my $path = $output->path;
+    gone($c, "Output is no longer available.") unless $path && $MACHINE_LOCAL_STORE->isValidPath($path);
+
+    my ($stdout, $stderr);
+    run3(['nix-store', '--query', '--referrers', $path], \undef, \$stdout, \$stderr);
+    error($c, "‘nix-store --query --referrers’ failed: $stderr") if $? != 0;
+
+    $c->stash->{path} = $path;
+    $c->stash->{referrers} = [sort grep { $_ ne '' } split /\n/, $stdout];
+    $c->stash->{template} = 'referrers.tt';
+}
+
+
